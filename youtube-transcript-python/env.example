# YouTube Transcript Python Provider - Environment Variables
# Copy this file to .env and fill in your values
# 
# cp env.example .env
# nano .env

# API Key for authenticating requests to the service
# Generate with: openssl rand -hex 32
API_KEY=your-secret-api-key-here

# Google Cloud Project ID (optional, can be set via gcloud config)
PROJECT_ID=your-project-id

# Google Cloud Run Region (optional, defaults to asia-southeast1)
REGION=asia-southeast1

# Cookies file path (optional, helps bypass bot detection)
# Export cookies from browser using extension: Get cookies.txt LOCALLY
# Then upload to Cloud Run or use COOKIES_BASE64
COOKIES_FILE=/path/to/cookies.txt

# Cookies as base64 encoded string (optional, alternative to COOKIES_FILE)
# To encode: cat cookies.txt | base64
# Then set this env var in Cloud Run
COOKIES_BASE64=

# Proxy URL (optional, for additional bypass)
# Format: http://proxy-host:port or socks5://proxy-host:port
PROXY_URL=

# Max retry attempts when bot detection occurs (default: 3)
MAX_RETRIES=3

